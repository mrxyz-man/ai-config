// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`CLI command signature snapshots mcp help stays stable 1`] = `
"Usage: ai-config mcp [options] [command]

Manage MCP task integrations

Options:
  -h, --help                    display help for command

Commands:
  status [options]              Show MCP integration status
  connect [options] <provider>  Connect MCP provider for task sync
  disconnect [options]          Disconnect MCP provider and return tasks mode to
                                local
  help [command]                display help for command"
`;

exports[`CLI command signature snapshots questions help stays stable 1`] = `
"Usage: ai-config questions [options] [command]

Questionnaire management

Options:
  -h, --help        display help for command

Commands:
  status [options]  Show questionnaire completion status
  run [options]     Run questionnaire update cycle
  ask [options]     Run interactive questionnaire interview
  help [command]    display help for command"
`;

exports[`CLI command signature snapshots root help stays stable 1`] = `
"Usage: ai-config [options] [command]

Configuration and synchronization system for AI agents

Options:
  -V, --version       output the version number
  -h, --help          display help for command

Commands:
  init [options]      Bootstrap ./ai configuration
  sync [options]      Sync managed configuration layers
  resolve [options]   Build resolved agent configuration
  validate [options]  Run configuration validation
  explain [options]   Explain resolved provenance
  text                Text quality checks
  questions           Questionnaire management
  mcp                 Manage MCP task integrations
  tasks               Manage tasks operations
  help [command]      display help for command"
`;

exports[`CLI command signature snapshots tasks help stays stable 1`] = `
"Usage: ai-config tasks [options] [command]

Manage tasks operations

Options:
  -h, --help                          display help for command

Commands:
  enable [options]                    Enable task-first workflow
  disable [options]                   Disable task-first workflow
  intake [options] <text>             Create structured task from user text
  list [options]                      List tasks from local board
  plan [options] <taskId>             Generate execution plan for a task
  status [options] <taskId> <status>  Move task to another status
  sync [options]                      Sync tasks using configured MCP provider
  help [command]                      display help for command"
`;

exports[`CLI command signature snapshots text help stays stable 1`] = `
"Usage: ai-config text [options] [command]

Text quality checks

Options:
  -h, --help       display help for command

Commands:
  check [options]  Run text reliability checks
  help [command]   display help for command"
`;
